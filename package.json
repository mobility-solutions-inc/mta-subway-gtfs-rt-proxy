{
	"private": true,
	"name": "mta-subway-gtfs-rt-proxy",
	"description": "An HTTP service consolidating & normalizing the MTA (NYCT) Subway GTFS-Realtime feeds.",
	"version": "1.0.0",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"imports": {
		"#postgis-gtfs-importer": {
			"types": "./types/postgis-gtfs-importer-index.d.ts",
			"default": "./postgis-gtfs-importer/index.js"
		},
		"#postgis-gtfs-importer/import": {
			"types": "./types/postgis-gtfs-importer-import.d.ts",
			"default": "./postgis-gtfs-importer/import.js"
		}
	},
	"author": "Ontra Mobility",
	"homepage": "https://github.com/mobility-solutions-inc/mta-subway-gtfs-rt-proxy",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/mobility-solutions-inc/mta-subway-gtfs-rt-proxy.git"
	},
	"bugs": "https://github.com/mobility-solutions-inc/mta-subway-gtfs-rt-proxy/issues",
	"license": "ISC",
	"packageManager": "pnpm@11.7.0",
	"engines": {
		"node": ">=24"
	},
	"dependencies": {
		"etag": "^1.8.1",
		"ky": "^1.2.3",
		"lodash": "^4.17.21",
		"longfn": "^1.3.1",
		"p-limit": "^6.1.0",
		"pg": "^8.11.3",
		"pg-format": "^1.0.4",
		"pino": "^8.19.0",
		"prom-client": "^15.1.0",
		"protobufjs": "^7.2.6",
		"serve-buffer": "^3.0.3"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@ianvs/prettier-plugin-sort-imports": "4.7.1",
		"@types/etag": "^1.8.4",
		"@types/lodash": "^4.17.24",
		"@types/node": "24.13.2",
		"@types/pg": "^8.20.0",
		"@types/pg-format": "^1.0.5",
		"eslint": "^9.39.4",
		"eslint-plugin-import": "^2.32.0",
		"execa": "^9.3.0",
		"pino-pretty": "^11.0.0",
		"prettier": "3.9.0",
		"prom2javascript": "^0.2.0",
		"protobufjs-cli": "^1.1.2",
		"sample-gtfs-feed": "^0.13.0",
		"typescript": "~5.9.3",
		"typescript-eslint": "8.62.0"
	},
	"scripts": {
		"test": "./test/index.sh",
		"lint": "eslint --cache --cache-location .cache/.eslintcache",
		"format": "prettier --check . --ignore-path .prettierignore --ignore-path .gitignore --cache --cache-location .cache/.prettiercache",
		"format:fix": "prettier --write . --ignore-path .prettierignore --ignore-path .gitignore",
		"build:proto": "./build.sh",
		"typecheck": "pnpm run build:proto && tsc --noEmit",
		"build": "pnpm run build:proto && tsc && mkdir -p dist/lib && cp lib/mta-gtfs-realtime.pb.js lib/mta-gtfs-realtime.pb.d.ts dist/lib/",
		"check": "pnpm run format && pnpm run lint && pnpm run typecheck && pnpm run build && pnpm test",
		"prepublishOnly": "pnpm run check"
	}
}
